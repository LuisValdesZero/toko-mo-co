# ── Toko-Mo-Co — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are optional — Toko-Mo-Co works with sensible defaults.

# ── Provider API Keys (at least one required) ────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...

# ── Server ───────────────────────────────────────────────────────────────
# CONFIG_PORT=8081                       # HTTP listen port (default: 8081)
# CONFIG_ALLOWED_ORIGINS=*               # CORS origins for WebSocket ("*" or comma-separated URLs)

# ── Database ─────────────────────────────────────────────────────────────
# CONFIG_DB_PATH=proxy.db                # SQLite file path (default: proxy.db)
# CONFIG_DB_KEEP_DAYS=30                 # Days of request history to retain (default: 30)

# ── Upstream ─────────────────────────────────────────────────────────────
# CONFIG_UPSTREAM_TIMEOUT_SEC=300        # HTTP timeout for upstream requests in seconds (default: 300)

# ── Loop Detection ───────────────────────────────────────────────────────
# CONFIG_LOOP_THRESHOLD=3                # Similar requests before flagging (default: 3)
# CONFIG_LOOP_SIMILARITY=0.8             # Similarity threshold 0–1 (default: 0.8)
# CONFIG_LOOP_WINDOW_MINUTES=5           # Rolling window in minutes (default: 5)

# ── Dashboard ────────────────────────────────────────────────────────────
# CONFIG_HISTORY_LIMIT=200               # Requests replayed to new WS clients (default: 200)
# CONFIG_SESSION_MAX_AGE=24              # Hours before idle sessions are evicted (default: 24)
# CONFIG_SESSION_MAX_SIZE=10000          # Max in-memory sessions / LRU cap (default: 10000)

# ── Injection ────────────────────────────────────────────────────────────
# CONFIG_INJECTION_MODE=metadata         # "metadata" | "content" | "hybrid" (default: metadata)
# CONFIG_CONTENT_THRESHOLD=10.0          # Cost threshold to escalate to content injection (default: 10.0)

# ── Rules Engine ─────────────────────────────────────────────────────────
# CONFIG_RULES_ENABLED=true              # Enable the rules engine (default: true)

# ── Retry & Fallback ────────────────────────────────────────────────────
# CONFIG_RETRY_ENABLED=true              # Enable automatic retries (default: true)
# CONFIG_RETRY_MAX_ATTEMPTS=3            # Max retry attempts (default: 3)
# CONFIG_RETRY_INITIAL_DELAY=1000        # Initial retry delay in ms (default: 1000)
# CONFIG_RETRY_MAX_DELAY=30000           # Max retry delay in ms (default: 30000)
# CONFIG_FALLBACK_ENABLED=false          # Enable fallback to alternate providers (default: false)
# CONFIG_FALLBACK_STRATEGY=same_tier     # "any" | "same_tier" | "cheaper" (default: same_tier)

# ── Authentication ───────────────────────────────────────────────────────
# CONFIG_AUTH_ENABLED=false              # Require API keys for proxy endpoints (default: false)

# ── Response Cache ───────────────────────────────────────────────────────
# CONFIG_CACHE_ENABLED=true              # Enable exact-match response cache (default: true)
# CONFIG_CACHE_MAX_ENTRIES=1000          # Max cached responses (default: 1000)
# CONFIG_CACHE_TTL_MINUTES=60            # Default TTL in minutes (default: 60)
# CONFIG_CACHE_ONLY_TEMP0=true           # Only cache temperature=0 requests (default: true)

# ── PII Redaction ────────────────────────────────────────────────────────
# CONFIG_PII_ENABLED=false               # Enable PII/secret redaction (default: false)
# CONFIG_PII_MODE=redact                 # "redact" | "hash" | "placeholder" (default: redact)
# CONFIG_PII_CATEGORIES=                 # Comma-separated category keys, empty = all (default: all)

# ── Semantic Cache (experimental) ────────────────────────────────────────
# Requires an embedding API key (OpenAI or compatible).
# CONFIG_SEMANTIC_CACHE_ENABLED=false    # Enable embedding-based cache (default: false)
# CONFIG_SEMANTIC_CACHE_THRESHOLD=0.95   # Cosine similarity threshold 0–1 (default: 0.95)
# CONFIG_SEMANTIC_CACHE_MAX_VECTORS=10000 # Max stored vectors (default: 10000)
# CONFIG_EMBEDDING_PROVIDER=openai       # Embedding provider (default: openai)
# CONFIG_EMBEDDING_MODEL=text-embedding-3-small  # Embedding model (default: text-embedding-3-small)
# CONFIG_EMBEDDING_API_KEY=              # Embedding API key (falls back to OPENAI_API_KEY)

# ── Memory Layer (experimental) ──────────────────────────────────────────
# Agent memory extraction and retrieval. Requires embedding API key.
# CONFIG_MEMORY_ENABLED=false            # Enable memory extraction and retrieval (default: false)
# CONFIG_MEMORY_MAX_ENTRIES=10000        # Max stored memory facts (default: 10000)
# CONFIG_MEMORY_THRESHOLD=0.7            # Similarity threshold for retrieval 0–1 (default: 0.7)
# CONFIG_MEMORY_MAX_RESULTS=5            # Max memories injected per request (default: 5)
# CONFIG_MEMORY_RECENCY_LAMBDA=0.01      # Decay rate for recency-weighted scoring (default: 0.01)
# CONFIG_MEMORY_CONFLICT_THRESHOLD=0.85  # Similarity for conflict detection (default: 0.85)
# CONFIG_MEMORY_TTL_DAYS=90              # Days before unused memories are eviction candidates (default: 90)
